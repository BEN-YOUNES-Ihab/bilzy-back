# Postgres / Neon connection string. Use Neon's "pooled" connection (port 5432
# with -pooler in the host) for serverless workloads, or the direct connection
# for local development.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Firebase Admin credentials. Either point at a JSON service-account file...
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
# ...or set FIREBASE_PROJECT_ID alone and rely on Application Default Credentials
# (e.g. when running on Google Cloud).
FIREBASE_PROJECT_ID=your-firebase-project-id

# HTTP listen address.
PORT=8080

# Comma-separated list of allowed CORS origins. Use exp://... in dev with Expo.
CORS_ORIGINS=http://192.168.1.13:8082,http://localhost:19006

# Set to "debug" or "info". Affects slog level.
LOG_LEVEL=info
